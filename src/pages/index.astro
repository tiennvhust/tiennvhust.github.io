---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Timeline from '../components/Timeline.astro';
import Projects from '../components/Projects.astro';
import Publications from '../components/Publications.astro';
import Contact from '../components/Contact.astro';
import ChatWidget from '../components/ChatWidget.astro';
import { profile, education, experience } from '../data/resume';

const educationItems = education.map((e) => ({
  title: e.institution,
  subtitle: e.degree,
  location: e.location,
  period: e.period,
  summary: e.note,
}));

const experienceItems = experience.map((x) => ({
  title: x.company,
  subtitle: x.role,
  location: x.location,
  period: x.period,
  summary: x.summary,
  details: x.details,
}));
---

<Base title={profile.name}>
  <span id="top"></span>
  <Nav />
  <main>
    <Hero />
    <Timeline id="experience" heading="Work Experience" items={experienceItems} />
    <Timeline id="education" heading="Education" items={educationItems} />
    <Projects />
    <Publications />
    <Contact />
  </main>
  <ChatWidget />
</Base>
