---
import { publications } from '../data/resume';
---

<section id="publications" class="section">
  <div class="container">
    <h2 class="section-title reveal">Publications</h2>
    <ul class="pubs">
      {
        publications.map((pub) => (
          <li class="pub reveal">
            <i class="fa-solid fa-quote-left pub-icon" aria-hidden="true" />
            <p>
              <span set:html={pub.citation} />
              {pub.doiUrl && (
                <>
                  {'. doi: '}
                  <a href={pub.doiUrl} target="_blank" rel="noopener">
                    {pub.doiLabel ?? pub.doiUrl}
                  </a>
                </>
              )}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .pubs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pub {
    display: flex;
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.4rem;
  }
  .pub-icon {
    color: var(--maroon);
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }
  .pub p {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.95rem;
  }
  .pub :global(strong) {
    color: var(--text);
  }
</style>
