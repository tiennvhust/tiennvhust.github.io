---
import { contacts, profile } from '../data/resume';
const year = new Date().getFullYear();
---

<section id="contact" class="section contact">
  <div class="container">
    <h2 class="section-title reveal">Contact</h2>
    <p class="contact-lead reveal">
      Open to conversations about sensor systems, edge ML, and signal processing.
    </p>
    <div class="contact-grid">
      {
        contacts.map((c) => {
          const isLink = c.href && c.href.length > 0;
          const Tag = isLink ? 'a' : 'div';
          return (
            <Tag
              class="contact-card reveal"
              {...(isLink
                ? {
                    href: c.href,
                    ...(c.href.startsWith('http')
                      ? { target: '_blank', rel: 'noopener' }
                      : {}),
                  }
                : {})}
            >
              <i class={`${c.icon} c-icon`} style={`color:${c.color}`} aria-hidden="true" />
              <span>{c.label}</span>
            </Tag>
          );
        })
      }
    </div>
  </div>
  <footer class="footer">
    © {year} {profile.name}. Built with Astro.
  </footer>
</section>

<style>
  .contact { padding-bottom: 2rem; }
  .contact-lead {
    color: var(--text-dim);
    margin-top: -1rem;
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .contact-card {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1.2rem 1.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-weight: 500;
    transition: all 0.25s var(--ease);
    word-break: break-word;
  }
  a.contact-card:hover {
    border-color: var(--maroon-bright);
    transform: translateY(-3px);
    color: var(--text);
  }
  .c-icon { font-size: 1.5rem; flex-shrink: 0; width: 1.5rem; text-align: center; }

  .footer {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--text-faint);
    font-size: 0.85rem;
  }
</style>
