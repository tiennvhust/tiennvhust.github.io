---
export interface TimelineItem {
  title: string;
  subtitle: string;
  location: string;
  period: string;
  summary?: string;
  details?: string[];
}

interface Props {
  id: string;
  heading: string;
  items: TimelineItem[];
}

const { id, heading, items } = Astro.props;
---

<section id={id} class="section">
  <div class="container">
    <h2 class="section-title reveal">{heading}</h2>
    <ol class="timeline">
      {
        items.map((item) => (
          <li class="t-item reveal">
            <div class="t-dot" aria-hidden="true" />
            <div class="t-body">
              <div class="t-head">
                <h3>{item.title}</h3>
                <span class="t-period">{item.period}</span>
              </div>
              <p class="t-meta">
                <span class="t-subtitle">{item.subtitle}</span>
                <span class="t-loc"><i class="fa-solid fa-location-dot" /> {item.location}</span>
              </p>
              {item.summary && <p class="t-summary">{item.summary}</p>}
              {item.details && item.details.length > 0 && (
                <ul class="t-details">
                  {item.details.map((d) => (
                    <li set:html={d} />
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: var(--border);
  }
  .t-item {
    position: relative;
    padding-left: 2.4rem;
    padding-bottom: 2.5rem;
  }
  .t-item:last-child { padding-bottom: 0; }
  .t-dot {
    position: absolute;
    left: 0;
    top: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg);
    border: 3px solid var(--maroon);
  }
  .t-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .t-head h3 {
    font-size: 1.25rem;
    margin: 0;
    color: var(--text);
  }
  .t-period {
    font-size: 0.85rem;
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .t-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin: 0.35rem 0 0;
  }
  .t-subtitle {
    color: var(--maroon-bright);
    font-weight: 600;
  }
  .t-loc {
    color: var(--text-faint);
    font-size: 0.9rem;
  }
  .t-summary {
    margin: 0.7rem 0 0;
    color: var(--text-dim);
  }
  .t-details {
    margin: 0.6rem 0 0;
    padding-left: 1.1rem;
    color: var(--text-dim);
  }
  .t-details li { margin-bottom: 0.3rem; }
</style>
